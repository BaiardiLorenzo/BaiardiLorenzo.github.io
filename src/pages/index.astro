---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Icon from '../components/Icon.astro';
import portfolio from '../data/portfolio.json';
import profilePhoto from '../../images/profile.png';

const { profile, hero, about, skills, experience, projects, insights, contact, footer, ui } = portfolio;
const visible = <T extends { visible: boolean; order: number }>(items: T[]) => items.filter((item) => item.visible).sort((a, b) => a.order - b.order);
const localizedTerm = (value: string) => (portfolio.terms as Record<string, { en: string; it: string }>)[value] ?? { en: value, it: value };
const projectAlt = (title: { en: string; it: string }) => ({ en: ui.abstractProjectPreview.en.replace('{title}', title.en), it: ui.abstractProjectPreview.it.replace('{title}', title.it) });
const rights = (value: string) => value.replace('{year}', String(new Date().getFullYear()));
---
<BaseLayout>
  <Header />
  <main id="main-content">
    <section id="home" class="relative isolate overflow-hidden">
      <div class="pointer-events-none absolute -z-10 inset-0 overflow-hidden"><div class="absolute -top-40 right-[5%] h-96 w-96 rounded-full bg-indigo-400/20 blur-3xl"></div><div class="absolute top-56 -left-36 h-72 w-72 rounded-full bg-emerald-300/15 blur-3xl"></div></div>
      <div class="container grid min-h-[calc(100svh-4rem)] items-center gap-12 py-20 lg:grid-cols-[1.15fr_.85fr] lg:py-24">
        <div class="reveal">
          <p class="eyebrow mb-5" data-i18n data-en={hero.kicker.en} data-it={hero.kicker.it}>{hero.kicker.en}</p>
          <h1 class="max-w-3xl text-5xl font-black leading-[1.04] tracking-[-.055em] sm:text-6xl lg:text-7xl" data-i18n data-en={hero.title.en} data-it={hero.title.it} set:html={hero.title.en}></h1>
          <p class="mt-6 max-w-xl text-lg leading-8 text-muted" data-i18n data-en={hero.description.en} data-it={hero.description.it}>{hero.description.en}</p>
          <div class="mt-8 flex flex-wrap gap-3"><a class="button button-primary" href="#projects"><span data-i18n data-en={hero.primaryCta.en} data-it={hero.primaryCta.it}>{hero.primaryCta.en}</span><Icon name="arrow" size={18} /></a><a class="button button-secondary" href="#contact" data-i18n data-en={hero.secondaryCta.en} data-it={hero.secondaryCta.it}>{hero.secondaryCta.en}</a></div>
          <div class="mt-8"><SocialLinks /></div>
        </div>
        <div class="reveal relative mx-auto w-full max-w-md"><div class="absolute -inset-4 -z-10 rounded-[2.5rem] bg-gradient-to-br from-brand/20 to-emerald-300/20 blur-2xl"></div><div class="glass rounded-[2rem] p-5 shadow-2xl shadow-brand/10"><div class="aspect-[4/5] overflow-hidden rounded-[1.4rem] bg-slate-900"><img class="h-full w-full object-cover object-center" src={profilePhoto.src} width={profilePhoto.width} height={profilePhoto.height} alt={profile.image.alt.en} data-i18n-attr="alt" data-en-alt={profile.image.alt.en} data-it-alt={profile.image.alt.it} fetchpriority="high" /></div></div></div>
      </div>
      <a class="absolute bottom-6 left-1/2 hidden -translate-x-1/2 text-xs font-bold uppercase tracking-widest text-muted md:block" href="#about" data-i18n data-en={hero.scrollPrompt.en} data-it={hero.scrollPrompt.it}>{hero.scrollPrompt.en}</a>
    </section>

    <section id="about" class="section border-y border-line bg-surface"><div class="container"><header class="reveal max-w-3xl"><p class="eyebrow" data-i18n data-en={about.kicker.en} data-it={about.kicker.it}>{about.kicker.en}</p><h2 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl" data-i18n data-en={about.title.en} data-it={about.title.it}>{about.title.en}</h2><p class="mt-5 text-lg leading-8 text-muted" data-i18n data-en={about.text.en} data-it={about.text.it}>{about.text.en}</p></header><div class="mt-12 grid gap-5 lg:grid-cols-3"><article class="reveal rounded-2xl border border-line bg-canvas p-6"><p class="text-xs font-bold uppercase tracking-wider text-brand" data-i18n data-en={about.locationLabel.en} data-it={about.locationLabel.it}>{about.locationLabel.en}</p><p class="mt-3 flex items-center gap-2 text-xl font-black"><Icon name="pin" size={18}/><span data-i18n data-en={profile.location.en} data-it={profile.location.it}>{profile.location.en}</span></p><p class="mt-3 text-sm leading-6 text-muted" data-i18n data-en="Italian roots, open to international collaboration." data-it="Radici italiane, aperto a collaborazioni internazionali.">Radici italiane, aperto a collaborazioni internazionali.</p></article><article class="reveal rounded-2xl border border-line bg-canvas p-6 lg:col-span-2"><p class="text-xs font-bold uppercase tracking-wider text-brand" data-i18n data-en={about.focusLabel.en} data-it={about.focusLabel.it}>{about.focusLabel.en}</p><p class="mt-3 max-w-3xl text-xl font-black leading-8" data-i18n data-en={about.focus.en} data-it={about.focus.it}>{about.focus.en}</p></article><article class="reveal rounded-2xl border border-line bg-canvas p-6 lg:col-span-3"><p class="text-xs font-bold uppercase tracking-wider text-brand" data-i18n data-en={about.beyondWorkLabel.en} data-it={about.beyondWorkLabel.it}>{about.beyondWorkLabel.en}</p><p class="mt-3 max-w-4xl leading-7 text-muted" data-i18n data-en={about.interests.en} data-it={about.interests.it}>{about.interests.en}</p></article></div><div class="mt-5 grid gap-5 md:grid-cols-3">{visible(about.highlights).map((item) => <article class="reveal rounded-2xl border border-line bg-surface p-6"><h3 class="font-black" data-i18n data-en={item.title.en} data-it={item.title.it}>{item.title.en}</h3><p class="mt-2 text-sm leading-6 text-muted" data-i18n data-en={item.text.en} data-it={item.text.it}>{item.text.en}</p></article>)}</div></div></section>

    <section id="skills" class="section"><div class="container"><div class="reveal max-w-xl"><p class="eyebrow" data-i18n data-en={skills.kicker.en} data-it={skills.kicker.it}>{skills.kicker.en}</p><h2 class="mt-3 text-4xl font-black tracking-tight" data-i18n data-en={skills.title.en} data-it={skills.title.it}>{skills.title.en}</h2><p class="mt-4 leading-7 text-muted" data-i18n data-en={skills.description.en} data-it={skills.description.it}>{skills.description.en}</p></div><div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">{visible(skills.groups).map((group) => <article class="reveal rounded-2xl border border-line bg-surface p-6 shadow-sm"><h3 class="text-xl font-black" data-i18n data-en={group.name.en} data-it={group.name.it}>{group.name.en}</h3><p class="mt-1 text-sm text-muted" data-i18n data-en={group.description.en} data-it={group.description.it}>{group.description.en}</p><ul class="mt-6 grid gap-3">{group.items.map((skill) => { const name = localizedTerm(skill.name); return <li class="flex items-center gap-3 font-semibold"><span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-soft text-sm font-bold text-brand">{skill.icon}</span><span data-i18n data-en={name.en} data-it={name.it}>{name.en}</span></li>})}</ul></article>)}</div></div></section>

    <section id="experience" class="section border-y border-line bg-surface"><div class="container"><div class="reveal max-w-xl"><p class="eyebrow" data-i18n data-en={experience.kicker.en} data-it={experience.kicker.it}>{experience.kicker.en}</p><h2 class="mt-3 text-4xl font-black tracking-tight" data-i18n data-en={experience.title.en} data-it={experience.title.it}>{experience.title.en}</h2></div><div class="mt-12"><h3 class="text-2xl font-black" data-i18n data-en={experience.professionalTitle.en} data-it={experience.professionalTitle.it}>{experience.professionalTitle.en}</h3><ol class="mt-7 space-y-8 border-l-2 border-brand/30 pl-7">{visible(experience.items).filter((item) => item.order < 4).map((item) => <li class="reveal relative"><span class="absolute -left-[2.18rem] top-1.5 h-4 w-4 rounded-full border-4 border-surface bg-brand"></span><article class="rounded-2xl border border-line bg-canvas p-6"><div class="flex flex-wrap items-start justify-between gap-2"><div><h4 class="text-xl font-black" data-i18n data-en={item.title.en} data-it={item.title.it}>{item.title.en}</h4><p class="mt-1 font-semibold text-brand" data-i18n data-en={item.organization.en} data-it={item.organization.it}>{item.organization.en}</p></div><p class="text-sm font-bold text-muted" data-i18n data-en={item.period.en} data-it={item.period.it}>{item.period.en}</p></div><p class="mt-2 flex items-center gap-1 text-sm text-muted"><Icon name="pin" size={15}/><span data-i18n data-en={item.location.en} data-it={item.location.it}>{item.location.en}</span></p><p class="mt-4 leading-7 text-muted" data-i18n data-en={item.description.en} data-it={item.description.it}>{item.description.en}</p><ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-muted">{item.achievements.map((achievement) => <li data-i18n data-en={achievement.en} data-it={achievement.it}>{achievement.en}</li>)}</ul>{item.id === 'ntt-data' && <div class="mt-8 space-y-6 border-t border-line pt-6">{visible(about.selectedWork.groups).map((group) => <section class="rounded-xl border border-line bg-surface p-5"><div><p class="text-sm font-black text-brand" data-i18n data-en={group.organization.en} data-it={group.organization.it}>{group.organization.en}</p><p class="mt-1 text-sm text-muted" data-i18n data-en={group.role.en} data-it={group.role.it}>{group.role.en}</p></div><div class="mt-5 grid gap-4 lg:grid-cols-2">{group.items.map((project) => <article class="rounded-lg border border-line bg-canvas p-4"><h5 class="font-black" data-i18n data-en={project.title.en} data-it={project.title.it}>{project.title.en}</h5><p class="mt-2 text-sm leading-6 text-muted" data-i18n data-en={project.description.en} data-it={project.description.it}>{project.description.en}</p><ul class="mt-3 space-y-1 text-sm leading-6 text-muted">{project.contributions.map((contribution) => <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand"></span><span data-i18n data-en={contribution.en} data-it={contribution.it}>{contribution.en}</span></li>)}</ul><div class="mt-4 flex flex-wrap gap-2">{project.tags.map((tag) => { const label = localizedTerm(tag); return <span class="tag" data-i18n data-en={label.en} data-it={label.it}>{label.en}</span>})}</div></article>)}</div>{group.collaboration && <div class="mt-5 rounded-lg bg-brand-soft p-4"><p class="text-sm font-black" data-i18n data-en={group.collaboration.title.en} data-it={group.collaboration.title.it}>{group.collaboration.title.en}</p><ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-muted">{group.collaboration.items.map((activity) => <li data-i18n data-en={activity.en} data-it={activity.it}>{activity.en}</li>)}</ul></div>}</section>)}</div>}<div class="mt-5 flex flex-wrap gap-2">{item.tags.map((tag) => { const label = localizedTerm(tag); return <span class="tag" data-i18n data-en={label.en} data-it={label.it}>{label.en}</span>})}</div></article></li>)}</ol></div><div class="mt-16"><h3 class="text-2xl font-black" data-i18n data-en={experience.educationTitle.en} data-it={experience.educationTitle.it}>{experience.educationTitle.en}</h3><ol class="mt-7 space-y-8 border-l-2 border-brand/30 pl-7">{visible(experience.items).filter((item) => item.order >= 4).map((item) => <li class="reveal relative"><span class="absolute -left-[2.18rem] top-1.5 h-4 w-4 rounded-full border-4 border-surface bg-brand"></span><article class="rounded-2xl border border-line bg-canvas p-6"><div class="flex flex-wrap items-start justify-between gap-2"><div><h4 class="text-xl font-black" data-i18n data-en={item.title.en} data-it={item.title.it}>{item.title.en}</h4><p class="mt-1 font-semibold text-brand" data-i18n data-en={item.organization.en} data-it={item.organization.it}>{item.organization.en}</p></div><p class="text-sm font-bold text-muted" data-i18n data-en={item.period.en} data-it={item.period.it}>{item.period.en}</p></div><p class="mt-2 flex items-center gap-1 text-sm text-muted"><Icon name="pin" size={15}/><span data-i18n data-en={item.location.en} data-it={item.location.it}>{item.location.en}</span></p><p class="mt-4 leading-7 text-muted" data-i18n data-en={item.description.en} data-it={item.description.it}>{item.description.en}</p><ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-muted">{item.achievements.map((achievement) => <li data-i18n data-en={achievement.en} data-it={achievement.it}>{achievement.en}</li>)}</ul><div class="mt-5 flex flex-wrap gap-2">{item.tags.map((tag) => { const label = localizedTerm(tag); return <span class="tag" data-i18n data-en={label.en} data-it={label.it}>{label.en}</span>})}</div></article></li>)}</ol></div></div></section>

    <section id="projects" class="section border-y border-line bg-surface"><div class="container"><div class="reveal flex flex-wrap items-end justify-between gap-5"><div><p class="eyebrow" data-i18n data-en={projects.kicker.en} data-it={projects.kicker.it}>{projects.kicker.en}</p><h2 class="mt-3 text-4xl font-black tracking-tight" data-i18n data-en={projects.title.en} data-it={projects.title.it}>{projects.title.en}</h2></div><a class="text-sm font-bold text-brand hover:underline" href={profile.social.github} target="_blank" rel="noreferrer" data-i18n data-en={projects.githubCta.en} data-it={projects.githubCta.it}>{projects.githubCta.en}</a></div><div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">{visible(projects.items).map((project) => { const alt = projectAlt(project.title); return <article class="reveal group overflow-hidden rounded-2xl border border-line bg-surface shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand/10"><img class="aspect-[1.6] w-full object-cover transition duration-500 group-hover:scale-105" src={project.image} alt={alt.en} data-i18n-attr="alt" data-en-alt={alt.en} data-it-alt={alt.it} loading="lazy" width="800" height="500"/><div class="p-6"><div class="flex items-center justify-between gap-2"><span class="tag" data-i18n data-en={project.category.en} data-it={project.category.it}>{project.category.en}</span><span class="text-xs font-bold text-muted" data-i18n data-en={project.date.en} data-it={project.date.it}>{project.date.en}</span></div><h3 class="mt-4 text-xl font-black" data-i18n data-en={project.title.en} data-it={project.title.it}>{project.title.en}{project.featured && <span class="ml-2 text-sm text-brand" aria-hidden="true">★</span>}</h3><p class="mt-2 text-sm leading-6 text-muted" data-i18n data-en={project.description.en} data-it={project.description.it}>{project.description.en}</p><div class="mt-5 flex flex-wrap gap-2">{project.technologies.map((technology) => { const label = localizedTerm(technology); return <span class="tag" data-i18n data-en={label.en} data-it={label.it}>{label.en}</span>})}</div><div class="mt-6 flex gap-4 text-sm font-bold">{project.github && <a class="inline-flex items-center gap-1 hover:text-brand" href={project.github} target="_blank" rel="noreferrer" data-i18n data-en={projects.code.en} data-it={projects.code.it}>{projects.code.en}<Icon name="github" size={16}/></a>}{project.confidential && <span class="text-muted" data-i18n data-en={projects.caseStudyOnly.en} data-it={projects.caseStudyOnly.it}>{projects.caseStudyOnly.en}</span>}</div></div></article>})}</div></div></section>

    <section id="insights" class="section"><div class="container"><div class="reveal max-w-2xl"><p class="eyebrow" data-i18n data-en={insights.kicker.en} data-it={insights.kicker.it}>{insights.kicker.en}</p><h2 class="mt-3 text-4xl font-black tracking-tight" data-i18n data-en={insights.title.en} data-it={insights.title.it}>{insights.title.en}</h2><p class="mt-4 leading-7 text-muted" data-i18n data-en={insights.description.en} data-it={insights.description.it}>{insights.description.en}</p></div><div class="mt-10 grid gap-5 md:grid-cols-3">{visible(insights.items).map((post) => <article class="reveal flex flex-col rounded-2xl border border-line bg-canvas p-6"><div class="flex items-center justify-between gap-3"><span class="tag" data-i18n data-en={post.category.en} data-it={post.category.it}>{post.category.en}</span><span class="text-xs font-bold uppercase tracking-wider text-muted" data-i18n data-en={post.published.en} data-it={post.published.it}>{post.published.en}</span></div><h3 class="mt-5 text-xl font-black" data-i18n data-en={post.title.en} data-it={post.title.it}>{post.title.en}</h3><p class="mt-3 text-sm leading-6 text-muted" data-i18n data-en={post.excerpt.en} data-it={post.excerpt.it}>{post.excerpt.en}</p><a class="mt-6 text-sm font-bold text-brand hover:underline" href={`/blog/${post.id}`} data-i18n data-en={insights.readLabel.en} data-it={insights.readLabel.it}>{insights.readLabel.en} →</a></article>)}</div></div></section>

    <section id="contact" class="section"><div class="container reveal overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand to-violet-800 px-6 py-14 text-white sm:px-12"><div class="grid items-end gap-10 md:grid-cols-[1.2fr_.8fr]"><div><p class="text-xs font-bold uppercase tracking-[.16em] text-indigo-200" data-i18n data-en={contact.kicker.en} data-it={contact.kicker.it}>{contact.kicker.en}</p><h2 class="mt-4 max-w-xl text-4xl font-black tracking-tight sm:text-5xl" data-i18n data-en={contact.title.en} data-it={contact.title.it}>{contact.title.en}</h2><p class="mt-5 max-w-lg leading-7 text-indigo-100" data-i18n data-en={contact.text.en} data-it={contact.text.it}>{contact.text.en}</p></div><div class="md:text-right"><a class="button bg-white text-brand hover:bg-indigo-50" href={`mailto:${profile.email}`}><span data-i18n data-en={contact.cta.en} data-it={contact.cta.it}>{contact.cta.en}</span><Icon name="arrow" size={18}/></a><p class="mt-5 text-sm text-indigo-100">{profile.email}<br /><span data-i18n data-en={profile.location.en} data-it={profile.location.it}>{profile.location.en}</span></p></div></div></div></section>
  </main>
  <footer class="border-t border-line bg-surface py-8"><div class="container flex flex-col gap-5 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"><div><p data-i18n data-en={rights(footer.rights.en)} data-it={rights(footer.rights.it)}>{rights(footer.rights.en)}</p><p class="mt-1" data-i18n data-en={footer.builtWith.en} data-it={footer.builtWith.it}>{footer.builtWith.en}</p></div><div class="flex items-center gap-3"><SocialLinks compact /><a class="font-bold hover:text-brand" href="#home" data-i18n data-en={footer.backToTop.en} data-it={footer.backToTop.it}>{footer.backToTop.en}</a></div></div></footer>
  <script>
    const observer = new IntersectionObserver((entries) => entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); } }), { threshold: .12 });
    document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));
    document.querySelectorAll<HTMLElement>('#projects article').forEach((card) => {
      const link = card.querySelector<HTMLAnchorElement>('a[href]');
      if (!link) return;
      card.tabIndex = 0;
      card.setAttribute('role', 'link');
      card.addEventListener('click', (event) => { if (!(event.target instanceof HTMLAnchorElement)) link.click(); });
      card.addEventListener('keydown', (event) => { if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); link.click(); } });
    });
  </script>
</BaseLayout>
